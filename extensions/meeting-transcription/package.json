{
  "name": "@pm-os/meeting-transcription",
  "version": "0.1.0",
  "private": true,
  "displayName": "Meeting Transcription",
  "description": "Auto-transcribe meetings with speaker labels. Powered by Whisper + Pyannote. 100% local.",
  "main": "./dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --external:electron --external:whisper-node-addon --outfile=dist/index.js --sourcemap",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@pm-os/types": "workspace:*",
    "@pm-os/event-bus": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
