{
  "name": "@pm-os/notion-panel",
  "version": "0.1.0",
  "private": true,
  "displayName": "PM-OS Notion Panel",
  "description": "Embedded Notion panel for PM-OS",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --external:electron --outfile=dist/index.js --sourcemap",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@pm-os/types": "workspace:*",
    "@pm-os/event-bus": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
