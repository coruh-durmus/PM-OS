{
  "name": "@pm-os/auth",
  "version": "0.1.0",
  "private": true,
  "displayName": "PM-OS Auth",
  "description": "Authentication and credential management for PM-OS",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
