    "clean": "rm -rf dist",
    "test": "echo 'No tests yet'"
  },
  "dependencies": {
    "@pm-os/types": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  }
}
