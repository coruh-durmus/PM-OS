{
  "name": "@pm-os/auth-backend",
  "version": "0.1.0",
  "private": true,
  "description": "OAuth backend service for PM-OS",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --packages=external --outfile=dist/index.js --sourcemap",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "@hono/node-server": "^1.14.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "@types/pg": "^8.11.0"
  }
}
